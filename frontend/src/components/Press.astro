---
// Presse-Bereich (§A5) — Materialien für Redaktionen, Freie Presse, MDR etc.
const asset = (p) => import.meta.env.BASE_URL.replace(/\/$/, '') + (p.startsWith('/') ? p : '/' + p);

const facts = [
  { label: 'Teilnehmer', value: 'Marc-Aurel Spalek & Lennard Weitzmann' },
  { label: 'Unternehmen', value: 'Wirth & Wiener GmbH, Chemnitz' },
  { label: 'Disziplin', value: 'Landschaftsgärtner (Landscape Gardening)' },
  { label: 'Bundesland', value: 'Sachsen' },
  { label: 'Wettkampf', value: '48. WorldSkills, Shanghai' },
  { label: 'Datum', value: '22.–27. September 2026' },
  { label: 'Ort', value: 'National Exhibition and Convention Center' },
  { label: 'Teilnehmende', value: 'über 1.400 aus 70+ Ländern' },
  { label: 'Disziplinen', value: '64 Berufe · Team Germany: 36 in 31' },
  { label: 'Schirmherr', value: 'Bundeskanzler Friedrich Merz' },
];
---

<section class="press" id="presse" aria-labelledby="press-title">
  <div class="press__inner u-container">
    <div class="press__header">
      <p class="u-eyebrow">Für die Presse</p>
      <h2 id="press-title" class="press__title">Pressematerial</h2>
      <p class="press__lead">
        Alle Infos und Materialien für Redaktionen – kostenlos zur Berichterstattung nutzbar.
      </p>
    </div>

    <div class="press__grid">
      <!-- Eckdaten -->
      <div class="press__card">
        <h3 class="press__card-title">
          <i class="fa-solid fa-circle-info" aria-hidden="true"></i> Eckdaten
        </h3>
        <dl class="press__facts">
          {facts.map(f => (
            <>
              <dt>{f.label}</dt>
              <dd>{f.value}</dd>
            </>
          ))}
        </dl>
      </div>

      <!-- Pressefotos -->
      <div class="press__card">
        <h3 class="press__card-title">
          <i class="fa-solid fa-images" aria-hidden="true"></i> Pressefotos
        </h3>
        <p class="press__card-text">
          Eigene Fotos von Marc-Aurel &amp; Lennard zur redaktionellen Nutzung (Bildcredit: <em>© Wirth &amp; Wiener GmbH</em>). Offizielle Wettkampf-Fotos &amp; -Videos stellt WorldSkills Germany während der WM frei bereit.
        </p>
        <a href="https://www.flickr.com/photos/worldskills-germany/albums" target="_blank" rel="noopener" class="press__dl-btn">
          <i class="fa-brands fa-flickr" aria-hidden="true"></i>
          Offizielle Fotos (Flickr)
          <span class="press__badge">WorldSkills Germany</span>
        </a>
      </div>

      <!-- Pressemitteilung -->
      <div class="press__card">
        <h3 class="press__card-title">
          <i class="fa-solid fa-file-lines" aria-hidden="true"></i> Pressemitteilung
        </h3>
        <p class="press__card-text">
          <strong>Aus Chemnitz nach Shanghai</strong> – Marc-Aurel &amp; Lennard mit Team Germany bei den WorldSkills 2026 (Stand: 30.&nbsp;Juni 2026).
        </p>
        <a href="#pressetext" class="press__dl-btn">
          <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
          Pressemitteilung lesen
        </a>
      </div>

      <!-- Kontakt -->
      <div class="press__card press__card--contact">
        <h3 class="press__card-title">
          <i class="fa-solid fa-envelope" aria-hidden="true"></i> Pressekontakt
        </h3>
        <address class="press__contact">
          <strong>Wirth &amp; Wiener GmbH</strong><br />
          Presse- und Öffentlichkeitsarbeit<br />
          <a href="mailto:info@gumu-agentur.de">info@gumu-agentur.de</a>
        </address>
        <p class="press__contact-note">
          Wir freuen uns über Anfragen und stellen auf Wunsch Interviewtermine bereit.
        </p>
      </div>

      <!-- Offizielle Quellen & Hashtags -->
      <div class="press__card">
        <h3 class="press__card-title">
          <i class="fa-solid fa-link" aria-hidden="true"></i> Offizielle Quellen
        </h3>
        <dl class="press__facts">
          <dt>Event</dt>
          <dd><a href="https://worldskills2026.com/" target="_blank" rel="noopener">worldskills2026.com</a></dd>
          <dt>Motto</dt>
          <dd>„Maximal zusammen!"</dd>
          <dt>Hashtags</dt>
          <dd>#WorldSkillsShanghai · #maximalzusammen · #teamgermany2026</dd>
          <dt>Veranstalter</dt>
          <dd>WorldSkills Germany e.&nbsp;V.<br /><a href="mailto:gradinger@worldskillsgermany.com">gradinger@worldskillsgermany.com</a></dd>
        </dl>
      </div>
    </div>

    <!-- Pressemitteilung (Volltext) -->
    <article class="press__release" id="pressetext" aria-labelledby="pressetext-title">
      <p class="u-eyebrow">Pressemitteilung · 30. Juni 2026</p>
      <h3 id="pressetext-title" class="press__release-title">
        Aus Chemnitz nach Shanghai: Wirth &amp; Wiener stellt zwei Landschaftsgärtner für Team Germany
      </h3>
      <p>
        <strong>Chemnitz, 30. Juni 2026</strong> – Zwei Landschaftsgärtner der Wirth &amp; Wiener GmbH aus Chemnitz,
        Marc-Aurel Spalek und Lennard Weitzmann, gehören zur Deutschen Berufe-Nationalmannschaft („Team Germany"),
        die vom 22. bis 27. September 2026 bei den WorldSkills in Shanghai antritt – der Weltmeisterschaft der Berufe.
        Beim Vorbereitungstreffen vom 25. bis 27. Juni im Neo Hotel Linde in Esslingen kam die Mannschaft erstmals komplett zusammen.
      </p>
      <p>
        Unter dem Motto „Maximal zusammen!" stimmten sich 36 Spitzenfachkräfte aus 31 Disziplinen fachlich, mental und
        persönlich auf die WM ein – mit Workshops, mentalem Training, Media Training und gemeinsamen Foto-Sessions.
        „Das Vorbereitungstreffen ist ein wichtiger Meilenstein auf dem Weg nach Shanghai. Hier wachsen die Teilnehmenden
        als Team zusammen", sagt Hubert Romer, Geschäftsführer von WorldSkills Germany.
      </p>
      <p>
        Ihr Ticket nach Shanghai lösten Spalek und Weitzmann mit dem Sieg beim bundesweiten Landschaftsgärtner-Cup 2025
        in Berlin. Seitdem trainieren die beiden bei Wirth &amp; Wiener in Chemnitz unter Wettkampf-Bedingungen, zuletzt
        bei der Landesmeisterschaft Sachsen in Dresden-Pillnitz. In Shanghai treten sie im Skill „Landscape Gardening" an,
        wenn Spitzenfachkräfte aus über 70 Ländern in 64 Disziplinen gegeneinander antreten.
      </p>
      <h4 class="press__release-sub">Über Wirth &amp; Wiener</h4>
      <p>
        Die Wirth &amp; Wiener GmbH aus Chemnitz ist spezialisiert auf Garten- und Landschaftsbau sowie Teich- und
        Schwimmteichbau. Das Unternehmen bildet aus und begleitet Marc-Aurel Spalek und Lennard Weitzmann auf ihrem Weg
        zur Berufs-Weltmeisterschaft.
      </p>
      <h4 class="press__release-sub">Bildmaterial</h4>
      <p>
        Offizielle Fotos von Team Germany (Mannschaftsfoto, Porträts) stellt WorldSkills Germany kostenlos bereit
        (© WorldSkills Germany / Frank Erpinar). Fotos von Marc-Aurel und Lennard auf Anfrage.
      </p>
      <p class="press__release-contact">
        <strong>Pressekontakt:</strong> GUMU Agentur · <a href="mailto:info@gumu-agentur.de">info@gumu-agentur.de</a>
      </p>
    </article>
  </div>
</section>

<style>
  .press {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(4rem, 10vh, 7rem);
    border-top: 1px solid rgba(201, 162, 75, 0.12);
  }

  .press__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
  }
  .press__title {
    font-size: var(--fs-h2);
    color: var(--gold);
    margin: 0.4rem 0 0.7rem;
  }
  .press__lead {
    color: var(--ink-soft);
    max-width: 50ch;
    margin-inline: auto;
    line-height: 1.6;
  }

  .press__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .press__grid { grid-template-columns: 1fr 1fr; }
  }

  .press__card {
    padding: clamp(1.4rem, 3vw, 2rem);
    border-radius: 12px;
    border: 1px solid rgba(201, 162, 75, 0.18);
    background: rgba(241, 232, 214, 0.03);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .press__card-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--gold);
  }
  .press__card-title i { font-size: 0.95rem; opacity: 0.85; }

  .press__card-text {
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .press__facts {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.35rem 1.1rem;
    font-size: 0.88rem;
  }
  .press__facts dt {
    color: var(--ink-soft);
    white-space: nowrap;
  }
  .press__facts dd {
    color: var(--paper);
    margin: 0;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .press__facts a { color: var(--gold); text-decoration: underline; }

  .press__dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    align-self: flex-start;
    margin-top: auto;
    padding: 0.65rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(201, 162, 75, 0.4);
    background: transparent;
    color: var(--gold);
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.22s ease, transform 0.18s var(--ease-out);
  }
  .press__dl-btn:hover { background: rgba(201, 162, 75, 0.12); transform: translateY(-2px); }

  /* „Noch nicht verfügbar" – ausgegraut, nicht klickbar */
  .press__card--soon { opacity: 0.62; }
  .press__dl-btn--disabled {
    border-color: rgba(241, 232, 214, 0.18);
    color: var(--ink-soft);
    cursor: default;
    pointer-events: none;
  }
  .press__dl-btn--disabled:hover { background: transparent; transform: none; }
  .press__badge {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  /* Pressemitteilung Volltext */
  .press__release {
    max-width: 70ch;
    margin: clamp(2rem, 5vh, 3.5rem) auto 0;
    padding-top: clamp(1.5rem, 4vh, 2.5rem);
    border-top: 1px solid rgba(201, 162, 75, 0.18);
    scroll-margin-top: 90px;
  }
  .press__release-title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    color: var(--gold);
    line-height: 1.25;
    margin: 0.4rem 0 1.1rem;
  }
  .press__release p {
    color: var(--ink-soft);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .press__release p strong { color: var(--paper); }
  .press__release-sub {
    font-family: var(--font-display);
    color: var(--gold);
    font-size: 1.02rem;
    margin: 1.4rem 0 0.4rem;
  }
  .press__release a { color: var(--gold); text-decoration: underline; }
  .press__release-contact { margin-top: 1.4rem; }

  .press__card--contact { border-color: rgba(201, 162, 75, 0.28); }
  .press__contact {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--paper);
  }
  .press__contact a { color: var(--gold); text-decoration: underline; }
  .press__contact-note {
    font-size: 0.82rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin-top: auto;
  }
</style>
