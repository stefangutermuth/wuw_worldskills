---
// DSGVO-konformer Cookie-Consent: Google Analytics (GA4) lädt NUR nach
// aktiver Zustimmung. Ohne „Akzeptieren" werden keine Skripte/Cookies geladen.
const GA_ID = 'G-BN8VT9XD9R';
---

<div class="cc" data-cc hidden role="dialog" aria-label="Cookie-Hinweis" aria-live="polite">
  <p class="cc__text">
    Wir verwenden <strong>Google Analytics</strong>, um die Nutzung dieser Seite anonymisiert zu verstehen.
    Cookies werden nur mit deiner Zustimmung gesetzt. Mehr dazu in der
    <a href="#datenschutz">Datenschutzerklärung</a>.
  </p>
  <div class="cc__actions">
    <button type="button" class="cc__btn cc__btn--ghost" data-cc-decline>Ablehnen</button>
    <button type="button" class="cc__btn cc__btn--gold" data-cc-accept>Akzeptieren</button>
  </div>
</div>

<script define:vars={{ GA_ID }}>
  const KEY = 'rts-consent-v1';

  function loadGA() {
    if (window.__gaLoaded) return;
    window.__gaLoaded = true;
    const s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    function gtag() { window.dataLayer.push(arguments); }
    window.gtag = gtag;
    gtag('js', new Date());
    gtag('config', GA_ID);
  }

  function getChoice() { try { return localStorage.getItem(KEY); } catch { return null; } }
  function save(v) { try { localStorage.setItem(KEY, v); } catch {} }
  function bar() { return document.querySelector('[data-cc]'); }

  function decide(v) {
    save(v);
    const b = bar();
    if (b) b.hidden = true;
    if (v === 'granted') loadGA();
  }

  // Startzustand
  const choice = getChoice();
  if (choice === 'granted') {
    loadGA();
  } else if (choice !== 'denied') {
    const show = () => { const b = bar(); if (b) b.hidden = false; };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', show, { once: true });
    else show();
  }

  // Robust: Delegation auf document (Capture-Phase) + Touch – greift unabhängig
  // von Timing/Re-Render und vor evtl. abfangenden Handlern.
  function onAct(e) {
    const el = e.target && e.target.closest ? e.target.closest('[data-cc-accept],[data-cc-decline]') : null;
    if (!el) return;
    e.preventDefault();
    decide(el.hasAttribute('data-cc-accept') ? 'granted' : 'denied');
  }
  document.addEventListener('click', onAct, true);
  document.addEventListener('touchend', onAct, true);
</script>

<style>
  .cc {
    position: fixed;
    left: 50%;
    bottom: clamp(0.8rem, 2.5vh, 1.6rem);
    transform: translateX(-50%);
    z-index: 9000;
    width: min(680px, calc(100% - 1.6rem));
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: 14px;
    border: 1px solid rgba(201, 162, 75, 0.3);
    background: rgba(14, 16, 22, 0.94);
    backdrop-filter: blur(10px);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.5);
    color: var(--paper);
  }
  .cc__text {
    font-size: 0.86rem;
    line-height: 1.5;
    color: rgba(241, 232, 214, 0.9);
    margin: 0;
  }
  .cc__text strong { color: var(--gold); font-weight: 600; }
  .cc__text a { color: var(--gold); text-decoration: underline; }
  .cc__actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
  .cc__btn {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .cc__btn--ghost {
    background: transparent;
    border: 1px solid rgba(241, 232, 214, 0.28);
    color: rgba(241, 232, 214, 0.8);
  }
  .cc__btn--ghost:hover { border-color: rgba(241, 232, 214, 0.5); color: var(--paper); }
  .cc__btn--gold {
    background: var(--gold);
    border: 1px solid var(--gold);
    color: #1a130a;
  }
  .cc__btn--gold:hover { background: #d8b760; }

  @media (max-width: 560px) {
    .cc { flex-direction: column; align-items: stretch; text-align: center; }
    .cc__actions { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cc { backdrop-filter: none; }
  }
</style>
