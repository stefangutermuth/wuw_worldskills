---
// Sektion „Daumendrücken" (§A3) — die teilbare Mitmach-Insel.
// Dynamische Insel: spricht GET/POST /rts/v1/cheer an.
---

<section class="cheer" id="daumendruecken" data-cheer aria-labelledby="cheer-title">
  <div class="cheer__bg" data-cheer-bg aria-hidden="true"></div>
  <div class="cheer__veil" aria-hidden="true"></div>
  <!-- Schwebende Laternen — eine pro Daumendrücker, von cheer.js erzeugt -->
  <div class="cheer__lanterns" data-cheer-lanterns aria-hidden="true"></div>
  <div class="cheer__grain atmo-grain atmo-grain--soft" aria-hidden="true"></div>

  <div class="cheer__inner u-container">
    <p class="u-eyebrow">Mitmachen</p>
    <h2 id="cheer-title" class="cheer__title">Drück die Daumen</h2>
    <p class="cheer__lead">
      Jede Laterne steigt für Marc-Aurel &amp; Lennard auf dem Weg nach Shanghai auf.
    </p>

    <!-- Start-Punkt der aufsteigenden Tap-Laternen -->
    <div class="cheer__launch" data-lantern-launch aria-hidden="true"></div>

    <button class="cheer__btn" data-cheer-btn type="button" aria-haspopup="dialog">
      <span class="cheer__btn-emoji" aria-hidden="true">🤞</span>
      <span class="cheer__btn-label">Daumen<br />drücken</span>
    </button>

    <p class="cheer__count-line">
      <span class="cheer__count" data-cheer-count>0</span>
      <span class="cheer__count-suffix">Fans drücken die Daumen</span>
    </p>

    <p class="cheer__msg" data-cheer-msg aria-live="polite">&nbsp;</p>
    <p class="cheer__ticker" data-cheer-ticker aria-live="polite">&nbsp;</p>
    <p class="cheer__hint">Tipp: Klick auf eine Laterne, um zu sehen, wer mitfiebert.</p>
  </div>

  <!-- Laternen-Tooltip -->
  <div class="cheer__tip" data-cheer-tip role="status"></div>

  <!-- Dialog: Name angeben? -->
  <div class="cheer__dialog" data-cheer-dialog hidden>
    <div class="cheer__dialog-card" role="dialog" aria-modal="true" aria-labelledby="cheer-dlg-title">
      <button class="cheer__dialog-close" data-cheer-close type="button" aria-label="Schließen">&times;</button>
      <span class="cheer__dialog-emoji" aria-hidden="true">🤞</span>
      <h3 id="cheer-dlg-title">Drück die Daumen!</h3>
      <p class="cheer__dialog-text">Magst du sagen, wer mitfiebert? Dann steigt deine Laterne mit Namen auf.</p>
      <div class="cheer__dialog-row">
        <input type="text" data-cheer-name placeholder="Vorname" maxlength="80" autocomplete="given-name" />
        <input type="text" data-cheer-ort placeholder="Ort" maxlength="120" autocomplete="address-level2" />
      </div>
      <label class="cheer__dialog-consent">
        <input type="checkbox" data-cheer-consent />
        <span>Vorname &amp; Ort dürfen öffentlich in einer Laterne erscheinen.</span>
      </label>
      <button class="cheer__dialog-confirm" data-cheer-confirm type="button">Daumen drücken 🤞</button>
      <button class="cheer__dialog-anon" data-cheer-anon type="button">Lieber anonym mitmachen</button>
      <p class="cheer__dialog-status" data-cheer-dialog-status aria-live="polite"></p>
    </div>
  </div>
</section>

<script>
  import { initCheer } from '../scripts/cheer.js';
  import { initBgParallax } from '../scripts/bgParallax.js';
  initCheer(document.querySelector('[data-cheer]'));
  initBgParallax(document.querySelector('[data-cheer-bg]'));
</script>

<style>
  .cheer {
    position: relative;
    overflow: hidden;
    color: var(--paper);
    padding-block: clamp(4rem, 12vh, 8rem);
    isolation: isolate;
    background: var(--night); /* Fallback hinter der Bild-Ebene */
  }

  /* Foto-Hintergrund als eigene Ebene (zoombar, mit Überstand gegen Kanten) */
  .cheer__bg {
    position: absolute;
    inset: -6%;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-image: url('/img/cheer/cheer-bg.jpg');
    background-image: image-set(
      '/img/cheer/cheer-bg.avif' type('image/avif'),
      '/img/cheer/cheer-bg.webp' type('image/webp'),
      '/img/cheer/cheer-bg.jpg' type('image/jpeg')
    );
    will-change: transform;
  }
  /* Dunkel-Schleier für Lesbarkeit über dem Foto */
  .cheer__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(12, 22, 34, 0.32) 0%, rgba(12, 22, 34, 0.08) 45%, rgba(22, 18, 15, 0.58) 100%);
  }

  /* Schwebende Laternen (echtes Bild, schwarzer HG via Screen-Blend) */
  .cheer__lanterns {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  /* Eine Laterne pro Daumendrücker – schwebt sanft an Ort und Stelle */
  .cheer__lantern {
    position: absolute;
    width: calc(54px * var(--s, 1));
    height: calc(76px * var(--s, 1));
    margin-left: calc(-27px * var(--s, 1));
    margin-top: calc(-38px * var(--s, 1));
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    background-image: url('/img/hero/lantern-glow.png');
    background-image: image-set(
      '/img/hero/lantern-glow.webp' type('image/webp'),
      '/img/hero/lantern-glow.png' type('image/png')
    );
    opacity: var(--o, 0.9);
    pointer-events: auto;
    cursor: pointer;
    will-change: transform;
    animation: cheer-lfloat var(--dur, 9s) ease-in-out var(--delay, 0s) infinite,
               cheer-lglow 3.6s ease-in-out infinite;
  }
  /* sanftes Schweben (bleibt im Bild) – berührt KEINE opacity */
  @keyframes cheer-lfloat {
    0%, 100% { transform: translate(0, 0); }
    25%      { transform: translate(var(--dx, 8px), calc(var(--dy, 12px) * -1)); }
    50%      { transform: translate(calc(var(--dx, 8px) * -0.6), var(--dy, 12px)); }
    75%      { transform: translate(calc(var(--dx, 8px) * 0.4), calc(var(--dy, 12px) * -0.5)); }
  }
  @keyframes cheer-lglow {
    0%, 100% { filter: brightness(0.9); }
    50%      { filter: brightness(1.14); }
  }
  .cheer__grain { z-index: 3; }

  .cheer__inner {
    position: relative;
    z-index: 4;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Klicks auf Leerflächen fallen zu den Laternen dahinter durch;
       nur interaktive Kinder (Daumen-Button) fangen sie wieder ab. */
    pointer-events: none;
  }

  .cheer__title {
    font-size: var(--fs-h2);
    color: var(--gold);
    margin: 0.4rem 0 0.75rem;
  }

  .cheer__lead {
    max-width: 40ch;
    color: var(--ink-soft);
    margin-bottom: clamp(2rem, 5vh, 3.5rem);
  }

  /* Laternen-Startpunkt: liegt mittig über dem Button, Laternen steigen daraus auf */
  .cheer__launch {
    position: relative;
    width: 100%;
    height: 0;
    z-index: 3;
    pointer-events: none;
  }

  .cheer__btn {
    position: relative;
    z-index: 3;
    pointer-events: auto; /* Button bleibt klickbar (Inner ist pointer-events:none) */
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: clamp(128px, 30vw, 162px);
    height: clamp(128px, 30vw, 162px);
    border-radius: 50%;
    border: none;
    color: var(--china-red-dk);
    background: radial-gradient(circle at 50% 30%, #fff3d4 0%, #ffdc8a 28%, #eaad42 60%, #bb772a 100%);
    box-shadow:
      inset 0 5px 16px rgba(255, 246, 220, 0.55),
      inset 0 -18px 34px rgba(120, 40, 20, 0.42),
      0 16px 46px rgba(201, 162, 75, 0.42);
    transition: transform 0.2s var(--ease-out), box-shadow 0.4s var(--ease-out);
  }
  .cheer__btn::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(201, 162, 75, 0.5);
    animation: cheer-ring 2.6s ease-out infinite;
    pointer-events: none;
  }
  .cheer__btn:hover { transform: translateY(-3px) scale(1.04); }
  .cheer__btn:active, .cheer__btn.is-pressed { transform: scale(0.95); }
  .cheer__btn:disabled { cursor: default; opacity: 0.92; }
  .cheer__btn-emoji {
    font-size: clamp(2.4rem, 6.5vw, 3.1rem);
    line-height: 1;
    filter: drop-shadow(0 2px 5px rgba(110, 19, 32, 0.3));
  }
  .cheer__btn-label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--fs-label);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.12;
    text-align: center;
  }
  @keyframes cheer-ring {
    0%   { box-shadow: 0 0 0 0 rgba(201, 162, 75, 0.45); opacity: 1; }
    70%  { box-shadow: 0 0 0 24px rgba(201, 162, 75, 0); opacity: 0; }
    100% { box-shadow: 0 0 0 0 rgba(201, 162, 75, 0); opacity: 0; }
  }

  .cheer__count-line {
    margin-top: clamp(1.75rem, 4vh, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .cheer__count {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--paper);
    font-variant-numeric: tabular-nums;
  }
  .cheer__count-suffix {
    font-size: var(--fs-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .cheer__ticker {
    margin-top: 1.5rem;
    min-height: 1.5em;
    font-size: var(--fs-body);
    color: var(--jade-lt);
  }
  .cheer__ticker :global(.cheer__ticker-pre) {
    color: var(--ink-soft);
    margin-right: 0.35rem;
  }

  .cheer__hint {
    margin-top: 1.5rem;
    font-size: var(--fs-label);
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }

  /* Laternen-Tooltip */
  .cheer__tip {
    position: absolute;
    z-index: 6;
    transform: translate(-50%, -125%);
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: rgba(8, 14, 22, 0.92);
    border: 1px solid rgba(201, 162, 75, 0.4);
    color: var(--paper);
    font-size: 0.85rem;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.45);
  }
  .cheer__tip.is-visible { opacity: 1; visibility: visible; }

  /* Dialog */
  .cheer__dialog {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: grid;
    place-items: center;
    padding: 1.25rem;
    background: rgba(6, 10, 16, 0.62);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .cheer__dialog.is-open { opacity: 1; }
  .cheer__dialog[hidden] { display: none; }
  .cheer__dialog-card {
    position: relative;
    width: min(30rem, 100%);
    text-align: center;
    padding: clamp(1.6rem, 4vw, 2.4rem);
    border-radius: 16px;
    border: 1px solid rgba(201, 162, 75, 0.35);
    background: linear-gradient(180deg, #14202b, #0d1620);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    transform: translateY(12px) scale(0.98);
    transition: transform 0.28s var(--ease-out);
  }
  .cheer__dialog.is-open .cheer__dialog-card { transform: translateY(0) scale(1); }
  .cheer__dialog-close {
    position: absolute;
    top: 0.5rem;
    right: 0.8rem;
    width: 2rem;
    height: 2rem;
    border: 0;
    background: transparent;
    color: var(--ink-soft);
    font-size: 1.7rem;
    line-height: 1;
    cursor: pointer;
  }
  .cheer__dialog-close:hover { color: var(--paper); }
  .cheer__dialog-emoji { font-size: 2.4rem; }
  .cheer__dialog-card h3 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--gold);
    margin: 0.3rem 0 0.4rem;
  }
  .cheer__dialog-text { color: var(--ink-soft); font-size: 0.95rem; margin-bottom: 1.1rem; }
  .cheer__dialog-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
  @media (max-width: 420px) { .cheer__dialog-row { grid-template-columns: 1fr; } }
  .cheer__dialog-row input {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius);
    border: 1px solid rgba(201, 162, 75, 0.3);
    background: rgba(255, 255, 255, 0.05);
    color: var(--paper);
    font: inherit;
  }
  .cheer__dialog-row input::placeholder { color: rgba(241, 232, 214, 0.4); }
  .cheer__dialog-consent {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    text-align: left;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--ink-soft);
    margin: 0.9rem 0 1.1rem;
  }
  .cheer__dialog-consent input { margin-top: 0.15rem; flex-shrink: 0; }
  .cheer__dialog-confirm {
    width: 100%;
    padding: 0.85rem;
    border-radius: 999px;
    border: 0;
    background: var(--gold);
    color: var(--china-red-dk);
    font: inherit;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: transform 0.18s var(--ease-out);
  }
  .cheer__dialog-confirm:hover { transform: translateY(-2px); }
  .cheer__dialog-confirm:disabled { opacity: 0.6; cursor: default; transform: none; }
  .cheer__dialog-anon {
    margin-top: 0.7rem;
    background: transparent;
    border: 0;
    color: var(--ink-soft);
    font: inherit;
    font-size: 0.9rem;
    text-decoration: underline;
    cursor: pointer;
  }
  .cheer__dialog-anon:hover { color: var(--paper); }
  .cheer__dialog-status { margin-top: 0.7rem; min-height: 1.1em; font-size: 0.85rem; }
  .cheer__dialog-status[data-kind='err'] { color: #ffc7b0; }

  /* Bestätigung am Daumen-Button */
  .cheer__msg {
    min-height: 1.4em;
    margin-top: 0.6rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--gold);
  }

  @media (prefers-reduced-motion: reduce) {
    .cheer__btn { animation: none; }
  }

  /* ---- dynamisch erzeugte Tap-Laternen (global, da per JS angelegt) ---- */
  :global(.cheer-lantern) {
    position: absolute;
    top: 0;
    width: 16px;
    height: 22px;
    margin-left: -8px;
    border-radius: 50% 50% 45% 45%;
    background: radial-gradient(circle at 50% 35%, #ffe09a, var(--gold) 60%, var(--china-red-dk));
    box-shadow: 0 0 18px var(--gold-glow);
    pointer-events: none;
    will-change: transform, opacity;
  }
  :global(.cheer-lantern)::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -5px;
    width: 2px;
    height: 5px;
    background: var(--gold);
    transform: translateX(-50%);
  }
</style>
