---
// Sektion „Daumendrücken" (§A3) — die teilbare Mitmach-Insel.
// Dynamische Insel: spricht GET/POST /rts/v1/cheer an.
---

<section class="cheer" id="daumendruecken" data-cheer aria-labelledby="cheer-title">
  <div class="cheer__bg" data-cheer-bg aria-hidden="true"></div>
  <div class="cheer__veil" aria-hidden="true"></div>
  <canvas class="cheer__canvas" data-cheer-canvas aria-hidden="true"></canvas>
  <div class="cheer__grain atmo-grain atmo-grain--soft" aria-hidden="true"></div>

  <div class="cheer__inner u-container">
    <p class="u-eyebrow">Mitmachen</p>
    <h2 id="cheer-title" class="cheer__title">Drück die Daumen</h2>
    <p class="cheer__lead">
      Jede Laterne steigt für Marc-Aurel &amp; Lennard auf dem Weg nach Shanghai auf.
    </p>

    <!-- Start-Punkt der aufsteigenden Tap-Laternen -->
    <div class="cheer__launch" data-lantern-launch aria-hidden="true"></div>

    <button class="cheer__btn" data-cheer-btn type="button">
      <span class="cheer__btn-emoji" aria-hidden="true">🤞</span>
      <span class="cheer__btn-label">Daumen drücken</span>
    </button>

    <p class="cheer__count-line">
      <span class="cheer__count" data-cheer-count>0</span>
      <span class="cheer__count-suffix">Fans drücken die Daumen</span>
    </p>

    <p class="cheer__msg" data-cheer-msg aria-live="polite">&nbsp;</p>

    <p class="cheer__ticker" data-cheer-ticker aria-live="polite">&nbsp;</p>

    <!-- Optional & unabhängig: mit Namen im Ticker erscheinen (eigener Button) -->
    <details class="cheer__optin">
      <summary>Mit deinem Namen im Live-Ticker erscheinen</summary>
      <div class="cheer__optin-fields">
        <div class="cheer__optin-row">
          <input type="text" data-cheer-name placeholder="Vorname" maxlength="80" autocomplete="given-name" />
          <input type="text" data-cheer-ort placeholder="Ort" maxlength="120" autocomplete="address-level2" />
        </div>
        <label class="cheer__consent">
          <input type="checkbox" data-cheer-consent />
          <span>Ich bin einverstanden, dass mein Vorname &amp; Ort öffentlich im Ticker angezeigt werden.</span>
        </label>
        <button type="button" class="cheer__optin-btn" data-cheer-name-submit>Im Ticker eintragen</button>
        <p class="cheer__optin-status" data-cheer-name-status aria-live="polite"></p>
      </div>
    </details>
  </div>
</section>

<script>
  import { initCheer } from '../scripts/cheer.js';
  import { initBgParallax } from '../scripts/bgParallax.js';
  initCheer(document.querySelector('[data-cheer]'));
  initBgParallax(document.querySelector('[data-cheer-bg]'));
</script>

<style>
  .cheer {
    position: relative;
    overflow: hidden;
    color: var(--paper);
    padding-block: clamp(4rem, 12vh, 8rem);
    isolation: isolate;
    background: var(--night); /* Fallback hinter der Bild-Ebene */
  }

  /* Foto-Hintergrund als eigene Ebene (zoombar, mit Überstand gegen Kanten) */
  .cheer__bg {
    position: absolute;
    inset: -6%;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-image: url('/img/cheer/cheer-bg.jpg');
    background-image: image-set(
      '/img/cheer/cheer-bg.avif' type('image/avif'),
      '/img/cheer/cheer-bg.webp' type('image/webp'),
      '/img/cheer/cheer-bg.jpg' type('image/jpeg')
    );
    will-change: transform;
  }
  /* Dunkel-Schleier für Lesbarkeit über dem Foto */
  .cheer__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(12, 22, 34, 0.32) 0%, rgba(12, 22, 34, 0.08) 45%, rgba(22, 18, 15, 0.58) 100%);
  }

  .cheer__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }
  .cheer__grain { z-index: 3; }

  .cheer__inner {
    position: relative;
    z-index: 4;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cheer__title {
    font-size: var(--fs-h2);
    color: var(--gold);
    margin: 0.4rem 0 0.75rem;
  }

  .cheer__lead {
    max-width: 40ch;
    color: var(--ink-soft);
    margin-bottom: clamp(2rem, 5vh, 3.5rem);
  }

  /* Laternen-Startpunkt: liegt mittig über dem Button, Laternen steigen daraus auf */
  .cheer__launch {
    position: relative;
    width: 100%;
    height: 0;
    z-index: 3;
    pointer-events: none;
  }

  .cheer__btn {
    position: relative;
    z-index: 3;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    width: clamp(150px, 40vw, 200px);
    height: clamp(150px, 40vw, 200px);
    border-radius: 50%;
    border: 2px solid rgba(201, 162, 75, 0.55);
    background:
      radial-gradient(circle at 50% 38%, #ffe6a8, var(--gold) 55%, var(--china-red) 120%);
    color: var(--china-red-dk);
    box-shadow:
      0 0 0 0 var(--gold-glow),
      0 18px 50px rgba(201, 162, 75, 0.35),
      inset 0 -8px 24px rgba(110, 19, 32, 0.25);
    transition: transform 0.18s var(--ease-out), box-shadow 0.4s var(--ease-out);
    animation: cheer-pulse 3.2s ease-in-out infinite;
  }
  .cheer__btn:hover {
    transform: translateY(-3px) scale(1.03);
  }
  .cheer__btn:active,
  .cheer__btn.is-pressed {
    transform: scale(0.94);
  }
  .cheer__btn:disabled {
    cursor: default;
    opacity: 0.92;
  }
  .cheer__btn-emoji {
    font-size: clamp(2.4rem, 7vw, 3.4rem);
    line-height: 1;
    filter: drop-shadow(0 2px 6px rgba(110, 19, 32, 0.3));
  }
  .cheer__btn-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  @keyframes cheer-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(201,162,75,0.4), 0 18px 50px rgba(201,162,75,0.35), inset 0 -8px 24px rgba(110,19,32,0.25); }
    50%      { box-shadow: 0 0 0 18px rgba(201,162,75,0), 0 18px 50px rgba(201,162,75,0.45), inset 0 -8px 24px rgba(110,19,32,0.25); }
  }

  .cheer__count-line {
    margin-top: clamp(1.75rem, 4vh, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .cheer__count {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--paper);
    font-variant-numeric: tabular-nums;
  }
  .cheer__count-suffix {
    font-size: var(--fs-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .cheer__ticker {
    margin-top: 1.5rem;
    min-height: 1.5em;
    font-size: var(--fs-body);
    color: var(--jade-lt);
  }
  .cheer__ticker :global(.cheer__ticker-pre) {
    color: var(--ink-soft);
    margin-right: 0.35rem;
  }

  /* Opt-in */
  .cheer__optin {
    margin-top: 2.5rem;
    max-width: 30rem;
    width: 100%;
    text-align: left;
    color: var(--ink-soft);
  }
  .cheer__optin summary {
    cursor: pointer;
    font-size: var(--fs-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    color: var(--gold);
    list-style: none;
  }
  .cheer__optin summary::-webkit-details-marker { display: none; }
  .cheer__optin-fields {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .cheer__optin input[type='text'] {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius);
    border: 1px solid rgba(201, 162, 75, 0.3);
    background: rgba(255, 255, 255, 0.04);
    color: var(--paper);
    font: inherit;
  }
  .cheer__optin input::placeholder { color: rgba(241, 232, 214, 0.4); }
  .cheer__consent {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .cheer__consent input { margin-top: 0.2rem; flex-shrink: 0; }

  .cheer__optin-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem;
  }
  @media (max-width: 480px) {
    .cheer__optin-row { grid-template-columns: 1fr; }
  }
  .cheer__optin-btn {
    align-self: flex-start;
    margin-top: 0.25rem;
    padding: 0.65rem 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--gold);
    background: var(--gold);
    color: var(--china-red-dk);
    font: inherit;
    font-weight: 600;
    font-size: 0.9rem;
    transition: transform 0.18s var(--ease-out), opacity 0.2s;
  }
  .cheer__optin-btn:hover { transform: translateY(-2px); }
  .cheer__optin-btn:disabled { opacity: 0.6; cursor: default; transform: none; }
  .cheer__optin-status { font-size: 0.85rem; min-height: 1.1em; }
  .cheer__optin-status[data-kind='ok'] { color: #bfe6cd; }
  .cheer__optin-status[data-kind='err'] { color: #ffc7b0; }

  /* Bestätigung am Daumen-Button */
  .cheer__msg {
    min-height: 1.4em;
    margin-top: 0.6rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--gold);
  }

  @media (prefers-reduced-motion: reduce) {
    .cheer__btn { animation: none; }
  }

  /* ---- dynamisch erzeugte Tap-Laternen (global, da per JS angelegt) ---- */
  :global(.cheer-lantern) {
    position: absolute;
    top: 0;
    width: 16px;
    height: 22px;
    margin-left: -8px;
    border-radius: 50% 50% 45% 45%;
    background: radial-gradient(circle at 50% 35%, #ffe09a, var(--gold) 60%, var(--china-red-dk));
    box-shadow: 0 0 18px var(--gold-glow);
    pointer-events: none;
    will-change: transform, opacity;
  }
  :global(.cheer-lantern)::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -5px;
    width: 2px;
    height: 5px;
    background: var(--gold);
    transform: translateX(-50%);
  }
</style>
