---
// Preloader / Intro-Overlay (§A0) — dunkler Tusche-Screen mit sich füllendem
// Gold-Ring + Wortmark, fährt nach window.load weich auf. Sperrt Scroll bis fertig,
// respektiert prefers-reduced-motion. Selbsttragend (kein GSAP nötig).
---

<!-- Scroll SOFORT sperren (läuft synchron, bevor der Rest des Body geparst wird) -->
<script is:inline>
  document.documentElement.classList.add('is-preloading');
</script>

<!-- Ohne JS: Overlay gar nicht erst zeigen und Scroll freigeben -->
<noscript>
  <style>
    .preloader { display: none !important; }
    html.is-preloading,
    html.is-preloading body { overflow: auto !important; }
  </style>
</noscript>

<div class="preloader" data-preloader>
  <div class="preloader__inner">
    <div class="preloader__meter">
      <svg class="preloader__ring" viewBox="0 0 120 120" aria-hidden="true">
        <circle class="preloader__track" cx="60" cy="60" r="54" />
        <circle class="preloader__bar" data-bar cx="60" cy="60" r="54" />
      </svg>
      <span class="preloader__percent" data-percent aria-hidden="true">0<small>%</small></span>
    </div>
    <div class="preloader__brand">
      <span class="preloader__kicker">Road to</span>
      <span class="preloader__script u-gold-sheen">Shanghai</span>
    </div>
  </div>
  <span class="u-visually-hidden" role="status">Seite wird geladen …</span>
</div>

<script>
  const el = document.querySelector('[data-preloader]');
  const html = document.documentElement;

  if (el) {
    const bar = el.querySelector('[data-bar]');
    const out = el.querySelector('[data-percent]');
    const C = 339.292; // Ring-Umfang (2π·54)
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let pct = 0;
    let loaded = false;
    let done = false;

    const draw = (v) => {
      const p = Math.min(100, Math.max(0, v));
      if (out) out.innerHTML = Math.round(p) + '<small>%</small>';
      if (bar) bar.style.strokeDashoffset = String(C * (1 - p / 100));
    };

    const leave = () => {
      if (done) return;
      done = true;
      draw(100);
      el.classList.add('is-leaving');
      html.classList.remove('is-preloading');
      document.dispatchEvent(new CustomEvent('preloader:done'));
      const remove = () => el.remove();
      el.addEventListener('transitionend', remove, { once: true });
      setTimeout(remove, 1000);
    };

    if (reduced) {
      // Kein Hochzählen — kurz 100 % zeigen, dann auf
      draw(100);
      const go = () => setTimeout(leave, 250);
      if (document.readyState === 'complete') go();
      else window.addEventListener('load', go, { once: true });
    } else {
      // Sanft hochzählen: Ziel ist 90 %, solange noch geladen wird; nach load → 100 %.
      const tick = () => {
        const target = loaded ? 100 : 90;
        pct += (target - pct) * 0.06; // weiches Annähern (kriecht Richtung 90 %)
        draw(pct);
        if (loaded && pct >= 99.4) {
          draw(100);
          leave();
          return;
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    const markLoaded = () => { loaded = true; };
    if (document.readyState === 'complete') markLoaded();
    else window.addEventListener('load', markLoaded, { once: true });

    // Sicherheitsnetz: spätestens nach 6 s sicher auf
    setTimeout(() => { loaded = true; setTimeout(leave, 400); }, 6000);
  }
</script>

<style>
  /* Scroll-Sperre während des Ladens */
  :global(html.is-preloading),
  :global(html.is-preloading body) {
    overflow: hidden !important;
    height: 100%;
  }

  .preloader {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: grid;
    place-items: center;
    background:
      radial-gradient(60% 55% at 50% 44%, rgba(201, 162, 75, 0.12), transparent 70%),
      radial-gradient(90% 80% at 80% 90%, rgba(12, 22, 34, 0.9), transparent 60%),
      #14100d;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out), visibility 0s linear 0.7s;
    will-change: opacity, transform;
  }
  /* feines Film-Korn */
  .preloader::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: var(--grain-svg);
    background-size: 200px 200px;
    opacity: 0.05;
    mix-blend-mode: screen;
  }
  .preloader.is-leaving {
    opacity: 0;
    visibility: hidden;
    transform: scale(1.05);
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
  }

  .preloader__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
  }

  /* ---------------- Gold-Ring + Prozentzahl ---------------- */
  .preloader__meter {
    position: relative;
    display: grid;
    place-items: center;
    width: clamp(110px, 22vw, 150px);
    height: clamp(110px, 22vw, 150px);
  }
  .preloader__ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg); /* Fortschritt beginnt oben */
  }
  .preloader__track {
    fill: none;
    stroke: rgba(201, 162, 75, 0.16);
    stroke-width: 3;
  }
  .preloader__bar {
    fill: none;
    stroke: var(--gold);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 339.292; /* 2π·54 */
    stroke-dashoffset: 339.292; /* leer; JS setzt den Fortschritt */
    filter: drop-shadow(0 0 6px var(--gold-glow));
    transition: stroke-dashoffset 0.12s linear;
  }
  .preloader__percent {
    position: absolute;
    font-family: var(--font-body);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    font-size: clamp(1.5rem, 4.5vw, 2.1rem);
    color: var(--paper);
    letter-spacing: 0.02em;
  }
  .preloader__percent small {
    font-size: 0.5em;
    color: var(--gold);
    margin-left: 0.1em;
    vertical-align: 0.35em;
  }

  /* ---------------- Wortmark ---------------- */
  .preloader__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
  }
  .preloader__kicker {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(0.7rem, 2.4vw, 0.95rem);
    letter-spacing: 0.42em;
    text-indent: 0.42em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .preloader__script {
    font-family: var(--font-script);
    font-weight: 400;
    font-size: clamp(2.4rem, 8vw, 3.6rem);
    line-height: 1.1;
    /* oben Luft für den „S"-Bogen (sonst schneidet background-clip:text ihn ab) */
    padding: 0.35em 0.12em 0.1em;
  }

  /* sanftes Einblenden des Inhalts beim Start */
  .preloader__inner {
    animation: pl-in 0.8s var(--ease-out) both;
  }
  @keyframes pl-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ---------------- reduced-motion ---------------- */
  @media (prefers-reduced-motion: reduce) {
    .preloader__bar { transition: none; }
    .preloader__inner { animation: none; }
    .preloader,
    .preloader.is-leaving { transition: opacity 0.3s linear, visibility 0s linear 0.3s; transform: none; }
  }
</style>
