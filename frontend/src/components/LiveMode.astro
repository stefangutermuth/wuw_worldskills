---
// Sektion „Live aus Shanghai" (§A4) – Reportage-Dashboard.
// Vor dem Event: Vorfreude (Countdown, Uhren, „Was dich erwartet").
// Während (Status=on / Dispatches vorhanden): Reportage (Featured + Karten).
const expect = [
  { ic: '📝', title: 'Tägliche Berichte', text: 'Jeden Tag ein kurzer Bericht direkt aus der Wettkampfhalle.' },
  { ic: '📸', title: 'Live-Fotos', text: 'Eindrücke vom Aufbau, vom Team und vom Schaugarten.' },
  { ic: '🏅', title: 'Ergebnisse', text: 'Wie schlagen sich die Jungs auf der Weltbühne?' },
];
// Public-Asset mit Base-Pfad (GitHub-Pages-Unterordner; lokal/Prod = '/').
const asset = (p) => import.meta.env.BASE_URL.replace(/\/$/, '') + (p.startsWith('/') ? p : '/' + p);
---

<section class="live" id="live" data-live="off" data-live-root aria-labelledby="live-title">
  <div class="live__bg" data-live-bg aria-hidden="true"></div>
  <div class="live__veil" aria-hidden="true"></div>
  <div class="live__grain atmo-grain atmo-grain--soft" aria-hidden="true"></div>

  <div class="live__inner u-container">
    <header class="live__head">
      <span class="live__badge">
        <span class="live__dot" aria-hidden="true"></span> Live aus Shanghai
      </span>
    </header>

    <h2 id="live-title" class="live__title">22.–27. September 2026</h2>

    <!-- Vorfreude (vor dem Event) -->
    <div class="live__pre" data-live-pre>
      <div class="live__cd">
        <span class="live__cd-num" data-live-days>–</span>
        <span class="live__cd-unit">Tage bis Shanghai</span>
      </div>
      <p class="live__cd-text">
        bis zum ersten Bericht direkt aus dem National Exhibition and Convention Center.
      </p>
    </div>

    <!-- Was dich erwartet -->
    <div class="live__expect" data-live-expect>
      {expect.map((c) => (
        <article class="live__expect-card">
          <span class="live__expect-ic" aria-hidden="true">{c.ic}</span>
          <h3>{c.title}</h3>
          <p>{c.text}</p>
        </article>
      ))}
    </div>

    <!-- Reportage (erscheint, sobald Berichte da sind) -->
    <div class="live__featured" data-live-featured hidden></div>
    <div class="live__cards" data-live-cards></div>

    <!-- Instagram-Feed-Vorschau (Stockbilder; später echter Feed übers Plugin) -->
    <div class="live__insta">
      <p class="live__insta-label">#RoadToShanghai auf Instagram</p>
      <div class="live__insta-grid">
        {[1, 2, 3, 4, 5].map((n) => (
          <figure class="live__insta-tile">
            <picture>
              <source srcset={asset(`/img/live/insta/insta-${n}.avif`)} type="image/avif" />
              <source srcset={asset(`/img/live/insta/insta-${n}.webp`)} type="image/webp" />
              <img src={asset(`/img/live/insta/insta-${n}.jpg`)} alt="" loading="lazy" width="600" height="600" />
            </picture>
          </figure>
        ))}
      </div>
      <p class="live__insta-note">Eindrücke von der Reise – bald mit echten Posts vom Wettkampf.</p>
    </div>
  </div>
</section>

<script>
  import { initLive } from '../scripts/live.js';
  initLive(document.querySelector('[data-live-root]'));
</script>

<style>
  .live {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: var(--paper);
    padding-block: clamp(4.5rem, 12vh, 8rem);
    background: var(--night); /* Fallback */
  }
  /* Shanghai-Nacht als zoombare Bild-Ebene */
  .live__bg {
    position: absolute;
    inset: -6%;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-image: url('/img/live/live-bg.jpg');
    background-image: image-set(
      '/img/live/live-bg.avif' type('image/avif'),
      '/img/live/live-bg.webp' type('image/webp'),
      '/img/live/live-bg.jpg' type('image/jpeg')
    );
    will-change: transform;
  }
  .live__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(100% 60% at 50% 0%, rgba(168, 30, 46, 0.22), transparent 55%),
      linear-gradient(180deg, rgba(8, 14, 22, 0.72) 0%, rgba(8, 14, 22, 0.5) 40%, rgba(8, 12, 16, 0.86) 100%);
  }
  .live__grain { z-index: 2; }
  .live__inner { position: relative; z-index: 3; }

  .live__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .live__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(168, 30, 46, 0.5);
    background: rgba(168, 30, 46, 0.16);
    font-size: var(--fs-label);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff9a8a;
  }
  .live__dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--china-red);
    animation: live-pulse 1.8s ease-out infinite;
  }
  @keyframes live-pulse {
    0% { box-shadow: 0 0 0 0 rgba(168, 30, 46, 0.6); }
    70% { box-shadow: 0 0 0 9px rgba(168, 30, 46, 0); }
    100% { box-shadow: 0 0 0 0 rgba(168, 30, 46, 0); }
  }

  .live__title {
    font-size: var(--fs-h2);
    color: var(--paper);
    margin: 0.5rem 0 0;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  }

  /* ---------- Vorfreude-Block ---------- */
  .live__pre {
    margin-top: clamp(2rem, 5vh, 3rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  .live__cd { display: flex; align-items: baseline; gap: 0.8rem; }
  .live__cd-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4rem, 13vw, 8.5rem);
    line-height: 0.9;
    color: var(--gold);
    font-variant-numeric: tabular-nums;
    text-shadow: 0 6px 40px var(--gold-glow);
  }
  .live__cd-unit {
    font-size: clamp(1rem, 2.4vw, 1.6rem);
    font-family: var(--font-display);
    font-style: italic;
    color: var(--paper);
  }
  .live__cd-text { max-width: 44ch; color: var(--ink-soft); margin-top: -0.5rem; }

  /* ---------- Was dich erwartet ---------- */
  .live__expect {
    margin-top: clamp(2.5rem, 6vh, 4rem);
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .live__expect { grid-template-columns: repeat(3, 1fr); } }
  .live__expect-card {
    padding: 1.4rem 1.5rem;
    border: 1px solid rgba(201, 162, 75, 0.2);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(3px);
  }
  .live__expect-ic { font-size: 1.6rem; }
  .live__expect-card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--gold);
    margin: 0.5rem 0 0.3rem;
  }
  .live__expect-card p { color: var(--ink-soft); font-size: 0.95rem; }

  /* on / Dispatches → Vorfreude weicht der Reportage */
  .live[data-live='on'] .live__pre,
  .live[data-dispatches='yes'] .live__pre,
  .live[data-dispatches='yes'] .live__expect { display: none; }

  /* ---------- Reportage ---------- */
  .live__featured {
    margin-top: 2.5rem;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid rgba(201, 162, 75, 0.25);
    background: rgba(255, 255, 255, 0.03);
  }
  :global(.live__featured-img) { width: 100%; height: auto; display: block; }
  :global(.live__featured-body) { padding: clamp(1.25rem, 3vw, 2rem); }
  :global(.live__featured-title) { font-size: clamp(1.5rem, 3vw, 2.2rem); margin: 0.4rem 0 0.6rem; color: var(--gold); }

  .live__cards {
    margin-top: 1.5rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .live__cards { grid-template-columns: 1fr 1fr; } }
  :global(.live__card) {
    border: 1px solid rgba(201, 162, 75, 0.2);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }
  :global(.live__card-img) { width: 100%; height: auto; display: block; }
  :global(.live__card h4) { font-family: var(--font-display); font-size: 1.3rem; margin: 0.3rem 0; padding-inline: 1rem; }
  :global(.live__card p) { padding: 0 1rem 1rem; color: var(--ink-soft); }
  :global(.live__date) {
    display: inline-block;
    padding: 0.75rem 1rem 0;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ---------- Instagram ---------- */
  .live__insta { margin-top: clamp(3rem, 7vh, 4.5rem); }
  .live__insta-label {
    font-size: var(--fs-label);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .live__insta-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.6rem;
    overflow-x: auto;
  }
  @media (max-width: 600px) {
    .live__insta-grid { grid-template-columns: repeat(5, minmax(100px, 1fr)); }
  }

  .live__insta-tile {
    position: relative;
    margin: 0;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgba(201, 162, 75, 0.18);
  }
  :global(.live__insta-tile img) {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) brightness(0.96);
    transition: transform 0.55s var(--ease-out), filter 0.4s ease;
  }
  .live__insta-tile::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(12, 22, 34, 0.5));
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .live__insta-tile:hover :global(img) { transform: scale(1.08); filter: saturate(1.12) brightness(1.05); }
  .live__insta-tile:hover::after { opacity: 1; }

  .live__insta-note {
    margin-top: 1rem;
    font-size: var(--fs-label);
    color: var(--ink-soft);
    font-style: italic;
  }
</style>
