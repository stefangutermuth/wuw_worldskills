---
// Sektion „Live aus Shanghai" (§A4) – Reportage-Dashboard.
// Vor dem Event: Vorfreude (Countdown, Uhren, „Was dich erwartet").
// Während (Status=on / Dispatches vorhanden): Reportage (Featured + Karten).
const expect = [
  { ic: '📝', title: 'Tägliche Berichte', text: 'Jeden Tag ein kurzer Bericht direkt aus der Wettkampfhalle.' },
  { ic: '📸', title: 'Live-Fotos', text: 'Eindrücke vom Aufbau, vom Team und vom Schaugarten.' },
  { ic: '🏅', title: 'Ergebnisse', text: 'Wie schlagen sich die Jungs auf der Weltbühne?' },
];
// Programm-Woche in Shanghai (Quelle: WorldSkills-Germany-Presseinfo).
const programm = [
  { date: '17. Sep', label: 'Anreise nach Shanghai' },
  { date: '22. Sep', label: 'Eröffnungsfeier' },
  { date: '23.–26. Sep', label: '4 Tage Wettkampf' },
  { date: '27. Sep', label: 'Siegerehrung & Abschluss' },
];
// Public-Asset mit Base-Pfad (GitHub-Pages-Unterordner; lokal/Prod = '/').
const asset = (p) => import.meta.env.BASE_URL.replace(/\/$/, '') + (p.startsWith('/') ? p : '/' + p);
---

<section class="live" id="live" data-live="off" data-live-root aria-labelledby="live-title">
  <div class="live__bg" data-live-bg aria-hidden="true"></div>
  <div class="live__veil" aria-hidden="true"></div>
  <div class="live__grain atmo-grain atmo-grain--soft" aria-hidden="true"></div>

  <div class="live__inner u-container">
    <header class="live__head">
      <span class="live__badge">
        <span class="live__dot" aria-hidden="true"></span> Live aus Shanghai
      </span>
    </header>

    <!-- AKTUELL (temporär – nach dem 20.06.2026 entfernen): Landschaftsgärtner-Cup Pillnitz -->
    <aside class="live__update">
      <span class="live__update-badge">Aktuell · 19.–20. Juni</span>
      <p class="live__update-text">
        <strong>Generalprobe in Pillnitz:</strong> Als amtierende Deutsche Meister treten Marc-Aurel &amp; Lennard beim <strong>Landschaftsgärtner-Cup Sachsen</strong> in Dresden-Pillnitz an – freiwillig und außerhalb der Wertung. Unter erschwerten Bedingungen (eine Stunde weniger Zeit, Baupläne erst am Wettkampftag) ist es die perfekte Vorbereitung auf Shanghai. 🌿
      </p>
      <p class="live__update-meta">Lohmener Str. 10, Dresden-Pillnitz · Eintritt frei · Sa zusätzlich Pillnitzer Gartentag</p>
    </aside>

    <!-- Vorfreude (vor dem Event): Zahl · Label · Datum in einer zentrierten Zeile -->
    <div class="live__pre" data-live-pre>
      <h2 id="live-title" class="live__cd">
        <span class="live__cd-num" data-live-days>–</span>
        <span class="live__cd-unit">Tage bis Shanghai</span>
        <span class="live__cd-sep" aria-hidden="true">·</span>
        <span class="live__cd-date">22.–27. September 2026</span>
      </h2>
      <p class="live__cd-text">
        bis zum ersten Bericht direkt aus dem National Exhibition and Convention Center.
      </p>
    </div>

    <!-- Was dich erwartet -->
    <div class="live__expect" data-live-expect>
      {expect.map((c) => (
        <article class="live__expect-card">
          <span class="live__expect-ic" aria-hidden="true">{c.ic}</span>
          <h3>{c.title}</h3>
          <p>{c.text}</p>
        </article>
      ))}
    </div>

    <!-- Programm-Woche in Shanghai -->
    <div class="live__programm">
      <h3 class="live__sub">Das Programm in Shanghai</h3>
      <ol class="live__timeline">
        {programm.map((p) => (
          <li class="live__tl-item">
            <span class="live__tl-date">{p.date}</span>
            <span class="live__tl-label">{p.label}</span>
          </li>
        ))}
      </ol>
      <div class="live__notes">
        <p class="live__note">
          <i class="fa-solid fa-ticket-simple" aria-hidden="true"></i>
          Du reist mit nach Shanghai? <a href="https://worldskills2026.com/" target="_blank" rel="noopener">Tickets für Eröffnung &amp; Siegerehrung</a> gibt es über die offizielle Event-Seite.
        </p>
        <p class="live__note">
          <span class="mascot-dot mascot-dot--blue" aria-hidden="true"></span>
          <span class="mascot-dot mascot-dot--red" aria-hidden="true"></span>
          Die Maskottchen 2026: <strong>Neng Neng</strong> &amp; <strong>Qiao Qiao</strong> – Motto „Master Skills, Change Your Future".
        </p>
      </div>
    </div>

    <!-- Reportage (erscheint, sobald Berichte da sind) -->
    <div class="live__featured" data-live-featured hidden></div>
    <div class="live__cards" data-live-cards></div>

    <!-- Instagram-Feed-Vorschau (Stockbilder; später echter Feed übers Plugin) -->
    <div class="live__insta">
      <p class="live__insta-label">#RoadToShanghai auf Instagram</p>
      <div class="live__insta-grid" data-insta-grid>
        {[1, 2, 3, 4, 5].map((n) => (
          <figure class="live__insta-tile">
            <picture>
              <source srcset={asset(`/img/live/insta/insta-${n}.avif`)} type="image/avif" />
              <source srcset={asset(`/img/live/insta/insta-${n}.webp`)} type="image/webp" />
              <img src={asset(`/img/live/insta/insta-${n}.jpg`)} alt="" loading="lazy" width="600" height="600" />
            </picture>
          </figure>
        ))}
      </div>
      <p class="live__insta-note">Eindrücke von der Reise – bald mit echten Posts vom Wettkampf.</p>
      <p class="live__hashtags">#WorldSkillsShanghai · #maximalzusammen · #teamgermany2026</p>
    </div>
  </div>
</section>

<script>
  import { initLive } from '../scripts/live.js';
  initLive(document.querySelector('[data-live-root]'));
</script>

<style>
  .live {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: var(--paper);
    padding-block: clamp(4.5rem, 12vh, 8rem);
    background: var(--night); /* Fallback */
  }
  /* Shanghai-Nacht als zoombare Bild-Ebene */
  .live__bg {
    position: absolute;
    inset: -6%;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-image: url('/img/live/live-bg.jpg');
    background-image: image-set(
      '/img/live/live-bg.avif' type('image/avif'),
      '/img/live/live-bg.webp' type('image/webp'),
      '/img/live/live-bg.jpg' type('image/jpeg')
    );
    /* Skyline ist sehr hell/bunt → für Lesbarkeit deutlich abdunkeln */
    filter: brightness(0.5) saturate(0.9);
    will-change: transform;
  }
  .live__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(100% 60% at 50% 0%, rgba(168, 30, 46, 0.16), transparent 55%),
      linear-gradient(180deg, rgba(8, 14, 22, 0.82) 0%, rgba(8, 14, 22, 0.66) 45%, rgba(8, 12, 16, 0.92) 100%);
  }
  .live__grain { z-index: 2; }
  .live__inner { position: relative; z-index: 3; }

  .live__head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .live__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(168, 30, 46, 0.5);
    background: rgba(168, 30, 46, 0.16);
    font-size: var(--fs-label);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ff9a8a;
  }
  .live__dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--china-red);
    animation: live-pulse 1.8s ease-out infinite;
  }
  @keyframes live-pulse {
    0% { box-shadow: 0 0 0 0 rgba(168, 30, 46, 0.6); }
    70% { box-shadow: 0 0 0 9px rgba(168, 30, 46, 0); }
    100% { box-shadow: 0 0 0 0 rgba(168, 30, 46, 0); }
  }

  /* ---------- Vorfreude-Block (zentriert) ---------- */
  .live__pre {
    margin-top: clamp(1.4rem, 3.5vh, 2.2rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.7rem;
  }
  /* Zahl · Label · Datum in EINER zentrierten Zeile (umbricht auf Schmal sauber) */
  .live__cd {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.35rem 0.7rem;
    margin: 0;
    line-height: 1.1;
  }
  .live__cd-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    line-height: 0.9;
    color: var(--gold);
    font-variant-numeric: tabular-nums;
    text-shadow: 0 4px 30px var(--gold-glow);
  }
  .live__cd-unit {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 2.4vw, 1.7rem);
    color: var(--paper);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }
  .live__cd-sep {
    color: rgba(201, 162, 75, 0.6);
    font-size: clamp(1rem, 2vw, 1.4rem);
  }
  .live__cd-date {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.6vw, 1.9rem);
    color: var(--gold);
    letter-spacing: 0.005em;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.6);
  }
  .live__cd-text {
    max-width: 50ch;
    margin: 0 auto;
    color: rgba(241, 232, 214, 0.92);
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.7);
  }

  /* ---------- Was dich erwartet ---------- */
  .live__expect {
    margin-top: clamp(1.5rem, 3.5vh, 2.4rem);
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .live__expect { grid-template-columns: repeat(3, 1fr); } }
  .live__expect-card {
    padding: 1.5rem 1.6rem;
    border: 1px solid rgba(201, 162, 75, 0.28);
    border-radius: var(--radius);
    background: rgba(9, 15, 24, 0.82);
    backdrop-filter: blur(10px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.38);
  }
  .live__expect-ic { font-size: 1.6rem; }
  .live__expect-card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--gold);
    margin: 0.5rem 0 0.3rem;
  }
  .live__expect-card p { color: rgba(241, 232, 214, 0.86); font-size: 0.96rem; }

  /* on / Dispatches → Vorfreude weicht der Reportage */
  .live[data-live='on'] .live__pre,
  .live[data-dispatches='yes'] .live__pre,
  .live[data-dispatches='yes'] .live__expect { display: none; }

  /* ---------- Reportage ---------- */
  .live__featured {
    margin-top: 2.5rem;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid rgba(201, 162, 75, 0.25);
    background: rgba(255, 255, 255, 0.03);
  }
  :global(.live__featured-img) { width: 100%; height: auto; display: block; }
  :global(.live__featured-body) { padding: clamp(1.25rem, 3vw, 2rem); }
  :global(.live__featured-title) { font-size: clamp(1.5rem, 3vw, 2.2rem); margin: 0.4rem 0 0.6rem; color: var(--gold); }

  .live__cards {
    margin-top: 1.5rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .live__cards { grid-template-columns: 1fr 1fr; } }
  :global(.live__card) {
    border: 1px solid rgba(201, 162, 75, 0.2);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }
  :global(.live__card-img) { width: 100%; height: auto; display: block; }
  :global(.live__card h4) { font-family: var(--font-display); font-size: 1.3rem; margin: 0.3rem 0; padding-inline: 1rem; }
  :global(.live__card p) { padding: 0 1rem 1rem; color: var(--ink-soft); }
  :global(.live__date) {
    display: inline-block;
    padding: 0.75rem 1rem 0;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ---------- Instagram ---------- */
  .live__insta { margin-top: clamp(1.8rem, 4vh, 3rem); }
  .live__insta-label {
    font-size: var(--fs-label);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .live__insta-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.6rem;
    overflow-x: auto;
  }
  @media (max-width: 600px) {
    .live__insta-grid { grid-template-columns: repeat(5, minmax(100px, 1fr)); }
  }

  /* global, damit auch die per JS eingefügten echten Instagram-Kacheln greifen */
  :global(.live__insta-tile) {
    position: relative;
    display: block;
    margin: 0;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgba(201, 162, 75, 0.18);
  }
  :global(.live__insta-tile img) {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) brightness(0.96);
    transition: transform 0.55s var(--ease-out), filter 0.4s ease;
  }
  :global(.live__insta-tile::after) {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(12, 22, 34, 0.5));
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  :global(.live__insta-tile:hover img) { transform: scale(1.08); filter: saturate(1.12) brightness(1.05); }
  :global(.live__insta-tile:hover::after) { opacity: 1; }

  .live__insta-note {
    margin-top: 1rem;
    font-size: var(--fs-label);
    color: var(--ink-soft);
    font-style: italic;
  }
  .live__hashtags {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--gold);
  }

  /* ---------- Aktuell-Karte (temporär) ---------- */
  .live__update {
    margin-top: clamp(1.5rem, 4vh, 2.2rem);
    padding: 1.2rem 1.4rem;
    border-radius: var(--radius);
    border: 1px solid rgba(201, 162, 75, 0.3);
    border-left: 3px solid var(--china-red);
    background: rgba(9, 15, 24, 0.82);
    backdrop-filter: blur(8px);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.35);
  }
  .live__update-badge {
    display: inline-block;
    margin-bottom: 0.55rem;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    background: rgba(168, 30, 46, 0.18);
    border: 1px solid rgba(168, 30, 46, 0.5);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ff9a8a;
  }
  .live__update-text {
    color: rgba(241, 232, 214, 0.9);
    line-height: 1.6;
    font-size: 0.96rem;
  }
  .live__update-text strong { color: var(--gold); }
  .live__update-meta {
    margin-top: 0.6rem;
    font-size: 0.82rem;
    color: var(--ink-soft);
  }

  /* ---------- Programm-Woche ---------- */
  .live__programm { margin-top: clamp(2.5rem, 6vh, 4rem); }
  .live__sub {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    color: var(--paper);
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .live__timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .live__timeline { grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  }
  .live__tl-item {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 1.1rem;
    border-radius: var(--radius);
    border: 1px solid rgba(201, 162, 75, 0.22);
    background: rgba(9, 15, 24, 0.82);
    backdrop-filter: blur(8px);
  }
  .live__tl-item::before {
    content: '';
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 10px var(--gold-glow);
    margin-bottom: 0.35rem;
  }
  .live__tl-date {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--gold);
  }
  .live__tl-label { font-size: 0.9rem; color: rgba(241, 232, 214, 0.86); }

  .live__notes {
    margin-top: 1.4rem;
    display: grid;
    gap: 0.7rem;
  }
  .live__note {
    font-size: 0.92rem;
    color: rgba(241, 232, 214, 0.82);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .live__note i { color: var(--gold); }
  .live__note strong { color: var(--paper); }
  .live__note a { color: var(--gold); text-decoration: underline; }
  .mascot-dot {
    display: inline-block;
    width: 10px; height: 10px; border-radius: 50%;
    transform: translateY(1px);
  }
  .mascot-dot--blue { background: #3aa0e0; box-shadow: 0 0 8px rgba(58, 160, 224, 0.6); }
  .mascot-dot--red { background: #e0533a; box-shadow: 0 0 8px rgba(224, 83, 58, 0.6); margin-left: -0.3rem; }
</style>
