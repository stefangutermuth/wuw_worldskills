---
// Footer (§A0): Newsletter, Sponsoren, Teilen, Rechtliches.
import Newsletter from './Newsletter.astro';
// Public-Asset mit Base-Pfad (GitHub-Pages-Unterordner; lokal/Prod = '/').
const asset = (p) => import.meta.env.BASE_URL.replace(/\/$/, '') + (p.startsWith('/') ? p : '/' + p);
---

<footer class="footer" id="newsletter">
  <div class="footer__inner u-container">
    <div class="footer__top">
      <!-- Newsletter (Anmeldung für Updates) -->
      <Newsletter compact />

      <!-- Teilen -->
      <div class="footer__share">
        <h3 class="footer__h">Teile das Abenteuer</h3>
        <p class="footer__lead">Hilf mit, dass möglichst viele die Daumen drücken.</p>
        <div class="footer__social" data-share>
          <a class="social-icon" data-share-wa target="_blank" rel="noopener" href="#" aria-label="Per WhatsApp teilen">
            <i class="fa-brands fa-whatsapp"></i>
          </a>
          <a class="social-icon" data-share-fb target="_blank" rel="noopener" href="#" aria-label="Auf Facebook teilen">
            <i class="fa-brands fa-facebook-f"></i>
          </a>
          <a class="social-icon" data-share-x target="_blank" rel="noopener" href="#" aria-label="Auf X teilen">
            <i class="fa-brands fa-x-twitter"></i>
          </a>
          <a class="social-icon" data-share-insta target="_blank" rel="noopener" href="https://www.instagram.com/" aria-label="Instagram">
            <i class="fa-brands fa-instagram"></i>
          </a>
          <button type="button" class="social-icon" data-share-copy aria-label="Link kopieren">
            <i class="fa-solid fa-link"></i>
          </button>
        </div>
        <p class="footer__share-status" data-share-status aria-live="polite"></p>
        <p class="footer__hashtags">#WorldSkillsShanghai · #maximalzusammen · #teamgermany2026</p>
      </div>
    </div>

    <!-- Sponsoren -->
    <div class="footer__sponsors">
      <p class="footer__sponsors-label">Unterstützt von</p>
      <div class="footer__sponsors-grid">
        <a class="sponsor__link" href="https://wirth-wiener.de" target="_blank" rel="noopener" aria-label="Wirth & Wiener GmbH – zur Website">
          <img class="sponsor__logo" src={asset('/img/logo-ww.svg')} alt="Wirth & Wiener GmbH" width="200" height="32" />
        </a>
        <a class="sponsor__link" href="https://www.galabau-sachsen.de" target="_blank" rel="noopener" aria-label="Verband Garten-, Landschafts- und Sportplatzbau Sachsen – zur Website">
          <img class="sponsor__logo sponsor__logo--galabau" src={asset('/img/logo-galabau.png')} alt="Ihre Experten für Garten & Landschaft – Garten- und Landschaftsbau Sachsen" width="190" height="60" />
        </a>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__brand">Road to Shanghai · Wirth &amp; Wiener GmbH</p>
      <nav class="footer__legal" aria-label="Rechtliches">
        <a href="#impressum">Impressum</a>
        <a href="#datenschutz" id="datenschutz">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<script>
  const root = document.querySelector('[data-share]');
  if (root) {
    const url = window.location.origin + '/';
    const title = 'Road to Shanghai – drück mit die Daumen!';
    const statusEl = document.querySelector('[data-share-status]');

    const wa = root.querySelector('[data-share-wa]');
    if (wa) wa.href = `https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}`;

    const fb = root.querySelector('[data-share-fb]');
    if (fb) fb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;

    const x = root.querySelector('[data-share-x]');
    if (x) x.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;

    const copy = root.querySelector('[data-share-copy]');
    copy?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        if (statusEl) statusEl.textContent = 'Link kopiert! 🔗';
        setTimeout(() => { if (statusEl) statusEl.textContent = ''; }, 3000);
      } catch {
        if (statusEl) statusEl.textContent = url;
      }
    });
  }
</script>

<style>
  .footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(3.5rem, 9vh, 6rem);
    border-top: 1px solid rgba(201, 162, 75, 0.18);
  }
  .footer__top {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    grid-template-columns: 1fr;
  }
  @media (min-width: 820px) {
    .footer__top { grid-template-columns: 1.2fr 1fr; align-items: start; }
  }
  .footer__h { font-size: 1.6rem; color: var(--gold); margin-bottom: 0.4rem; }
  .footer__lead { margin: 0 0 1.4rem; color: var(--ink-soft); font-size: 0.93rem; line-height: 1.55; }

  /* Social Icons */
  .footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    border: 1px solid rgba(201, 162, 75, 0.4);
    background: transparent;
    color: var(--gold);
    font-size: 1.05rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.22s ease, border-color 0.22s ease, transform 0.18s var(--ease-out);
  }
  .social-icon:hover {
    background: rgba(201, 162, 75, 0.16);
    border-color: var(--gold);
    transform: translateY(-3px);
    color: var(--gold);
  }
  .footer__share-status {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--jade-lt);
    min-height: 1.1em;
  }
  .footer__hashtags {
    margin-top: 0.5rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.01em;
  }

  .footer__sponsors {
    margin-top: clamp(3rem, 7vh, 4.5rem);
    padding-top: 2rem;
    border-top: 1px solid rgba(241, 232, 214, 0.1);
    text-align: center;
  }
  .footer__sponsors-label {
    font-size: var(--fs-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.25rem;
  }
  .footer__sponsors-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.25rem 2.75rem;
  }
  .sponsor__link { display: inline-flex; align-items: center; }
  /* Logos weiß auf dunklem Footer */
  .sponsor__logo {
    height: clamp(26px, 4vh, 34px);
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }
  .sponsor__logo:hover { opacity: 1; }
  /* GaLaBau-Logo (Text + Icon) etwas höher, damit die Zeilen lesbar bleiben */
  .sponsor__logo--galabau { height: clamp(36px, 5.5vh, 50px); }
  .sponsor {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.2;
    text-align: center;
    color: rgba(241, 232, 214, 0.7);
    padding: 0.5rem 1rem;
    border: 1px dashed rgba(201, 162, 75, 0.25);
    border-radius: var(--radius);
  }

  .footer__bottom {
    margin-top: clamp(2.5rem, 6vh, 4rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    font-size: var(--fs-label);
    color: var(--ink-soft);
  }
  .footer__legal { display: flex; gap: 1.5rem; }
  .footer__legal a:hover { color: var(--gold); }
</style>
