---
// Footer (§A0): Newsletter, Sponsoren, Teilen, Rechtliches.
import Newsletter from './Newsletter.astro';
---

<footer class="footer" id="newsletter">
  <div class="footer__inner u-container">
    <div class="footer__top">
      <!-- Newsletter (Anmeldung für Updates) -->
      <Newsletter compact />

      <!-- Teilen -->
      <div class="footer__share">
        <h3 class="footer__h">Teile das Abenteuer</h3>
        <p class="footer__lead">Hilf mit, dass möglichst viele die Daumen drücken.</p>
        <div class="footer__share-btns" data-share>
          <button type="button" class="share-btn" data-share-native hidden>Teilen</button>
          <a class="share-btn" data-share-wa target="_blank" rel="noopener" href="#">WhatsApp</a>
          <a class="share-btn" data-share-fb target="_blank" rel="noopener" href="#">Facebook</a>
          <button type="button" class="share-btn" data-share-copy>Link kopieren</button>
        </div>
        <p class="footer__share-status" data-share-status aria-live="polite"></p>
      </div>
    </div>

    <!-- Sponsoren -->
    <div class="footer__sponsors">
      <p class="footer__sponsors-label">Unterstützt von</p>
      <div class="footer__sponsors-grid" aria-hidden="true">
        <span class="sponsor">Wirth &amp; Wiener</span>
        <span class="sponsor">Logo</span>
        <span class="sponsor">Logo</span>
        <span class="sponsor">Logo</span>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__brand">Road to Shanghai · Wirth &amp; Wiener GmbH</p>
      <nav class="footer__legal" aria-label="Rechtliches">
        <a href="#impressum">Impressum</a>
        <a href="#datenschutz" id="datenschutz">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<script>
  const root = document.querySelector('[data-share]');
  if (root) {
    const url = window.location.origin + '/';
    const title = 'Road to Shanghai – drück mit die Daumen!';
    const statusEl = root.querySelector('[data-share-status]');

    const wa = root.querySelector('[data-share-wa]');
    if (wa) wa.href = `https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}`;
    const fb = root.querySelector('[data-share-fb]');
    if (fb) fb.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;

    const native = root.querySelector('[data-share-native]');
    if (native && navigator.share) {
      native.hidden = false;
      native.addEventListener('click', () => {
        navigator.share({ title, text: title, url }).catch(() => {});
      });
    }

    const copy = root.querySelector('[data-share-copy]');
    copy?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        if (statusEl) statusEl.textContent = 'Link kopiert! 🔗';
      } catch {
        if (statusEl) statusEl.textContent = url;
      }
    });
  }
</script>

<style>
  .footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(3.5rem, 9vh, 6rem);
    border-top: 1px solid rgba(201, 162, 75, 0.18);
  }
  .footer__top {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    grid-template-columns: 1fr;
  }
  @media (min-width: 820px) {
    .footer__top { grid-template-columns: 1.2fr 1fr; align-items: start; }
  }
  .footer__h { font-size: 1.6rem; color: var(--gold); }
  .footer__lead { margin: 0.5rem 0 1.25rem; color: var(--ink-soft); }

  .footer__share-btns { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .share-btn {
    padding: 0.65rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(201, 162, 75, 0.4);
    background: transparent;
    color: var(--paper);
    font: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.25s, transform 0.18s var(--ease-out);
  }
  .share-btn:hover { background: rgba(201, 162, 75, 0.14); transform: translateY(-2px); }
  .footer__share-status { margin-top: 0.75rem; font-size: 0.85rem; color: var(--jade-lt); min-height: 1.1em; }

  .footer__sponsors {
    margin-top: clamp(3rem, 7vh, 4.5rem);
    padding-top: 2rem;
    border-top: 1px solid rgba(241, 232, 214, 0.1);
    text-align: center;
  }
  .footer__sponsors-label {
    font-size: var(--fs-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.25rem;
  }
  .footer__sponsors-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 2.5rem;
  }
  .sponsor {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: rgba(241, 232, 214, 0.55);
    padding: 0.5rem 1rem;
    border: 1px dashed rgba(201, 162, 75, 0.25);
    border-radius: var(--radius);
  }

  .footer__bottom {
    margin-top: clamp(2.5rem, 6vh, 4rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    font-size: var(--fs-label);
    color: var(--ink-soft);
  }
  .footer__legal { display: flex; gap: 1.5rem; }
  .footer__legal a:hover { color: var(--gold); }
</style>
