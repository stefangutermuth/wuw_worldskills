---
// Basis-Layout — globale Styles, Meta, Fonts.
import '../styles/tokens.css';
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Road to Shanghai – WorldSkills 2026',
  description = 'Marc-Aurel Spalek & Lennard Weitzmann auf dem Weg zur WorldSkills 2026 in Shanghai. Begleite das Abenteuer von Wirth & Wiener.',
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#16120F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Hero-Bild vorladen (LCP) -->
    <link rel="preload" as="image" href="/img/hero/hero-bg.avif" type="image/avif" />

    <!-- Open Graph (Teilen) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />

    <title>{title}</title>
  </head>
  <body>
    <Preloader />
    <slot />
  </body>
</html>
