---
// Basis-Layout — globale Styles, Meta, Fonts, SEO.
import '../styles/tokens.css';
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'Road to Shanghai – WorldSkills 2026',
  description = 'Marc-Aurel Spalek & Lennard Weitzmann von Wirth & Wiener auf dem Weg zur WorldSkills 2026 – der Berufe-WM in Shanghai. Countdown, Live-Updates und Daumendrücken.',
  noindex = false,
} = Astro.props;
// Public-Asset mit Base-Pfad (GitHub-Pages-Unterordner; lokal/Prod = '/').
const asset = (p) => import.meta.env.BASE_URL.replace(/\/$/, '') + (p.startsWith('/') ? p : '/' + p);
const _base = import.meta.env.BASE_URL.replace(/\/$/, '');
const _ogOrigin = _base ? 'https://stefangutermuth.github.io' : 'https://shanghai.wirth-wiener.de';
const ogUrl = `${_ogOrigin}${_base}/`;
const ogImage = `${_ogOrigin}${_base}/img/hero/hero-bg.jpg`;

// Strukturierte Daten (JSON-LD): Organisation, Website, Event.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://wirth-wiener.de/#org',
      name: 'Wirth & Wiener GmbH',
      url: 'https://wirth-wiener.de',
      logo: `${_ogOrigin}${_base}/img/logo-ww.svg`,
      address: { '@type': 'PostalAddress', addressLocality: 'Chemnitz', addressCountry: 'DE' },
    },
    {
      '@type': 'WebSite',
      '@id': `${ogUrl}#website`,
      name: 'Road to Shanghai – WorldSkills 2026',
      url: ogUrl,
      inLanguage: 'de-DE',
      publisher: { '@id': 'https://wirth-wiener.de/#org' },
    },
    {
      '@type': 'Event',
      name: 'WorldSkills 2026 Shanghai',
      startDate: '2026-09-22',
      endDate: '2026-09-27',
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      url: 'https://worldskills2026.com/',
      location: {
        '@type': 'Place',
        name: 'National Exhibition and Convention Center (NECC)',
        address: { '@type': 'PostalAddress', addressLocality: 'Shanghai', addressCountry: 'CN' },
      },
      image: ogImage,
      description:
        '48. Berufe-Weltmeisterschaft WorldSkills 2026 in Shanghai – Marc-Aurel Spalek & Lennard Weitzmann von Wirth & Wiener treten in der Disziplin Landschaftsgärtnerei (Landscape Gardening) an.',
      organizer: { '@type': 'Organization', name: 'WorldSkills International', url: 'https://worldskills.org' },
      performer: [
        { '@type': 'Person', name: 'Marc-Aurel Spalek' },
        { '@type': 'Person', name: 'Lennard Weitzmann' },
      ],
    },
  ],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#16120F" />
    <!-- Google Search Console (Property shanghai.wirth-wiener.de) -->
    <meta name="google-site-verification" content="UI4X2dJxgh4J5leb29MhpB2xa1-rMR97PdSdx7-Wd0A" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={ogUrl} />
    <link rel="icon" type="image/svg+xml" href={asset('/favicon.svg')} />
    <link rel="sitemap" type="application/xml" href={asset('/sitemap.xml')} />

    <!-- Hero-Bild vorladen (LCP) -->
    <link rel="preload" as="image" href={asset('/img/hero/hero-bg.avif')} type="image/avif" />

    <!-- Open Graph (Teilen) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Road to Shanghai" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- Font Awesome 6 (Brand-Icons für Social) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    {!noindex && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <Preloader />
    <slot />
  </body>
</html>
