---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Route from '../components/Route.astro';
import Cheer from '../components/Cheer.astro';
import WishTree from '../components/WishTree.astro';
import LiveMode from '../components/LiveMode.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Header />

  <main>
    <!-- §A1 — Der Aufbruch (Hero + Split-Flap-Countdown) -->
    <Hero />

    <!-- Übergang Hero (Tusche-Dunkel) → Reise (Reispapier) -->
    <div class="seam" style="background: linear-gradient(180deg, #14100d, #ece2cf)" aria-hidden="true"></div>

    <!-- §A2 — Die Reise (Route-Scrollytelling) -->
    <Route />

    <!-- Übergang Reise (Reispapier) → Daumendrücken (Nachthimmel) -->
    <div class="seam" style="background: linear-gradient(180deg, #ece2cf, #0c1622)" aria-hidden="true"></div>

    <!-- §A3 — Daumendrücken (dynamische Insel, /cheer) -->
    <Cheer />

    <!-- §A3 — Wunschbaum (dynamische Insel, /wishes, moderiert) -->
    <WishTree />

    <!-- §A4 — Live aus Shanghai (Status-Toggle, /dispatches) -->
    <LiveMode />
  </main>

  <!-- Footer: Newsletter, Sponsoren, Teilen -->
  <Footer />
</Base>
