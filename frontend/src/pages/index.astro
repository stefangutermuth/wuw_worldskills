---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Route from '../components/Route.astro';
import Cheer from '../components/Cheer.astro';
import WishTree from '../components/WishTree.astro';
import LiveMode from '../components/LiveMode.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Header />

  <main>
    <!-- §A1 — Der Aufbruch (Hero + Split-Flap-Countdown) -->
    <Hero />

    <!-- §A2 — Die Reise (Route-Scrollytelling) -->
    <Route />

    <!-- §A3 — Daumendrücken (dynamische Insel, /cheer) -->
    <Cheer />

    <!-- §A3 — Wunschbaum (dynamische Insel, /wishes, moderiert) -->
    <WishTree />

    <!-- §A4 — Live aus Shanghai (Status-Toggle, /dispatches) -->
    <LiveMode />
  </main>

  <!-- Footer: Newsletter, Sponsoren, Teilen -->
  <Footer />
</Base>
