# Kopie als .env anlegen. REST-Basis-URL der Headless-WP-Installation.
PUBLIC_WP_API=http://worldskills-shanghai-2026.local/wp-json

# Optional: Cloudflare-Turnstile-Sitekey fürs Wunsch-Formular.
# Leer lassen = kein Widget (Backend lässt im Dev durch).
# Das zugehörige Secret kommt serverseitig in WP-Option `rts_turnstile_secret`.
PUBLIC_TURNSTILE_SITEKEY=
